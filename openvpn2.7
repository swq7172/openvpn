name: Build Windows Exe

on:
  # 手动点一下就编译
  workflow_dispatch:

jobs:
  build-windows:
    runs-on: windows-latest  # GitHub 免费 Windows 服务器
    steps:
      - name: 下载源码
        uses: actions/checkout@v4

      - name: 配置 CMake
        run: cmake -B build -S .

      - name: 编译 Release 版本
        run: cmake --build build --config Release

      - name: 上传编译好的 exe 文件
        uses: actions/upload-artifact@v4
        with:
          name: windows-exe
          path: build/Release/
